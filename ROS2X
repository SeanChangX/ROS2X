launch_gazebo() {
    echo "Launching Gazebo..."
    if ! container_running; then
        echo "Container '${PROJECT_NAME}' is not running. Starting it..."
        compose_up_with_strategy true
    fi

    set +e
    compose exec --user ros ${SERVICE_NAME} bash -lc '
        set -e
        set +u
        source "/opt/ros/${ROS_DISTRO:-humble}/setup.bash"
        if [ -f "/home/ros/ROS2X/ros2_ws/install/setup.bash" ]; then
            source "/home/ros/ROS2X/ros2_ws/install/setup.bash"
        fi
        set -u

        mkdir -p "/home/ros/ROS2X/apps/gazebo/config" "/home/ros/ROS2X/apps/gazebo/data"
        if [ -d "/home/ros/.gz" ] && [ ! -L "/home/ros/.gz" ]; then
            rm -rf "/home/ros/ROS2X/apps/gazebo/config/.gz"
            mv "/home/ros/.gz" "/home/ros/ROS2X/apps/gazebo/config/.gz"
        fi
        if [ -d "/home/ros/.ignition" ] && [ ! -L "/home/ros/.ignition" ]; then
            rm -rf "/home/ros/ROS2X/apps/gazebo/config/.ignition"
            mv "/home/ros/.ignition" "/home/ros/ROS2X/apps/gazebo/config/.ignition"
        fi
        ln -sfn "/home/ros/ROS2X/apps/gazebo/config/.gz" "/home/ros/.gz"
        ln -sfn "/home/ros/ROS2X/apps/gazebo/config/.ignition" "/home/ros/.ignition"
        mkdir -p "/home/ros/ROS2X/apps/gazebo/config/.gz" "/home/ros/ROS2X/apps/gazebo/config/.ignition"
        export XDG_CONFIG_HOME="/home/ros/ROS2X/apps/gazebo/config/xdg"
        export XDG_DATA_HOME="/home/ros/ROS2X/apps/gazebo/data/xdg"
        mkdir -p "${XDG_CONFIG_HOME}" "${XDG_DATA_HOME}"

        if ros2 pkg prefix ros_gz_sim >/dev/null 2>&1; then
            exec ros2 launch ros_gz_sim gz_sim.launch.py
        fi

        if command -v gz >/dev/null 2>&1; then
            exec gz sim
        fi

        echo "Error: Gazebo executable not found." >&2
        echo "Hint: rebuild image or install ros-${ROS_DISTRO:-humble}-ros-gz and ros-${ROS_DISTRO:-humble}-ros-gz-sim." >&2
        exit 1
    '
    gazebo_status=$?
    set -e
    echo "Gazebo exited. Container remains running for other tasks."
    echo "Use './ROS2X close' to stop and remove the container."
    return "${gazebo_status}"
}

open_xhost_if_needed() {
    case "${ACTION}" in
        build|run|app|bridge|rviz|gazebo|enter|--command)
            if command -v xhost >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]]; then
                xhost +local: >/dev/null 2>&1 || true
                XHOST_OPENED="true"
            fi
            ;;
    esac
}

cleanup() {
    if [[ "${XHOST_OPENED}" == "true" ]]; then
        xhost -local: >/dev/null 2>&1 || true
    fi
}
trap cleanup EXIT

write_env() {
    mkdir -p "${WORKSPACE_DIR}"
    mkdir -p "${WORKSPACE_DIR}/src"

    cat > "${DOCKER_DIR}/.env" <<EOL
# ========================================================
# AUTO-GENERATED FILE - DO NOT EDIT MANUALLY
# This file is overwritten by ./ROS2X on every command run.
#
# How to customize values:
# 1) One-off:   VAR=value ./ROS2X <command>
# 2) Persistent defaults: use ./ROS2X config set <KEY> <VALUE>
# ========================================================
#
# Docker Compose Settings
COMPOSE_PROJECT_NAME=${PROJECT_NAME}
COMPOSE_BAKE=true

# ROS Settings
ROS_DISTRO=${ROS_DISTRO}
ROS_INSTALL_TYPE=${ROS_INSTALL_TYPE}
ROS_DOMAIN_ID=${ROS_DOMAIN_ID}

# Project Settings
PROJECT_NAME=${PROJECT_NAME}
AUTO_BUILD=${AUTO_BUILD}
AUTO_RUN=${AUTO_RUN}
LAUNCH_COMMAND=${LAUNCH_COMMAND}
INSTALL_MICRO_ROS=${INSTALL_MICRO_ROS}
IMAGE_NAME=${IMAGE_NAME}
IMAGE_STRATEGY=${IMAGE_STRATEGY}
GROOT_VERSION=${GROOT_VERSION}
GROOT_FALLBACK_VERSIONS=${GROOT_FALLBACK_VERSIONS}
GROOT_APPIMAGE_URL=${GROOT_APPIMAGE_URL}
GROOT_SHA256=${GROOT_SHA256}
QGC_VERSION=${QGC_VERSION}
QGC_APPIMAGE_URL=${QGC_APPIMAGE_URL}
QGC_SHA256=${QGC_SHA256}
FOXGLOVE_PORT=${FOXGLOVE_PORT}
FOXGLOVE_ADDRESS=${FOXGLOVE_ADDRESS}

# Dynamic UID and GID
LOCAL_USER_ID=$(id -u)
LOCAL_GROUP_ID=$(id -g)
EOL
}

ensure_container_running() {
    if ! container_running; then
        echo "Container '${PROJECT_NAME}' is not running. Starting it..."
        compose_up_with_strategy true
    fi
}

if [[ "${ACTION}" == "--help" || "${ACTION}" == "-h" || -z "${ACTION}" ]]; then
    print_usage
    exit 0
fi

if [[ "${ACTION}" == "config" ]]; then
    handle_config_command "${ACTION_ARGS[@]}"
    exit $?
fi

case "${ACTION}" in
    image-build)
        AUTO_BUILD="false"
        AUTO_RUN="false"
        ;;
    build)
        AUTO_BUILD="true"
        AUTO_RUN="false"
        ;;
    run)
        AUTO_BUILD="false"
        AUTO_RUN="true"
        ;;
    bridge|rviz|gazebo|app|enter|close|--command)
        AUTO_BUILD="false"
        AUTO_RUN="false"
        ;;
    *)
        print_usage
        exit 1
        ;;
esac

write_env
validate_image_strategy
open_xhost_if_needed

if [[ "${ACTION}" == "close" ]]; then
    if docker_accessible; then
        echo "Stopping the container..."
        compose down || true
    else
        echo "Docker daemon is not accessible. Please check your Docker permissions."
    fi
    exit 0
fi

if ! docker_accessible; then
    echo "Docker daemon is not accessible. Please check your Docker permissions."
    exit 1
fi

case "${ACTION}" in
    image-build)
        echo "Building Docker image only..."
        compose build "${SERVICE_NAME}"
        ;;
    build)
        echo "Building ROS workspace..."
        compose_up_with_strategy
        ;;
    run)
        echo "Running launch command in container..."
        set +e
        compose_up_with_strategy
        run_status=$?
        set -e
        compose down || true
        exit "${run_status}"
        ;;
    bridge)
        launch_foxglove_bridge
        ;;
    rviz)
        launch_rviz
        ;;
    gazebo)
        launch_gazebo
        ;;
    app)
        launch_app "${ACTION_ARGS[0]:-}"
        ;;
    enter)
        echo "Entering the container..."
        ensure_container_running
        docker exec -it --user ros "${PROJECT_NAME}" bash || echo "Exited container without shutting it down."
        ;;
    --command)
        if [[ -z "${CUSTOM_COMMAND}" ]]; then
            echo "Error: No command specified for --command."
            exit 1
        fi
        ensure_container_running
        compose exec --user ros -e ROS2X_CUSTOM_COMMAND="${CUSTOM_COMMAND}" ${SERVICE_NAME} bash -lc '
            set -e
            set +u
            source "/opt/ros/${ROS_DISTRO:-humble}/setup.bash"
            if [ -f "/home/ros/ROS2X/ros2_ws/install/setup.bash" ]; then
                source "/home/ros/ROS2X/ros2_ws/install/setup.bash"
            fi
            set -u
            bash -lc "${ROS2X_CUSTOM_COMMAND}"
        '
        ;;
esac
