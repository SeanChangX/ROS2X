#!/usr/bin/env bash

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
DOCKER_DIR="${DIR}/docker"
CONFIG_DIR="${DIR}/config"
CONFIG_FILE="${CONFIG_DIR}/ros2x.conf"
CONFIG_TEMPLATE_FILE="${CONFIG_DIR}/ros2x.conf.example"
SERVICE_NAME="ros2x"
WORKSPACE_DIR="${DIR}/ros2_ws"

DEFAULT_ROS_DISTRO="humble"
DEFAULT_ROS_INSTALL_TYPE="ros-base"
DEFAULT_ROS_DOMAIN_ID="0"
DEFAULT_PROJECT_NAME="ros2x"
DEFAULT_INSTALL_MICRO_ROS="false"
DEFAULT_LAUNCH_COMMAND="echo '[TO-DO] Set LAUNCH_COMMAND in ROS2X'"
DEFAULT_IMAGE_STRATEGY="auto"
DEFAULT_IMAGE_REPOSITORY="ghcr.io/seanchangx/ros2x"
DEFAULT_GROOT_VERSION="1.9.0"
DEFAULT_GROOT_FALLBACK_VERSIONS="1.8.1,1.8.0,1.7.1,1.7.0,1.6.1"
DEFAULT_QGC_VERSION="latest"
DEFAULT_FOXGLOVE_PORT="8765"
DEFAULT_FOXGLOVE_ADDRESS="0.0.0.0"

CONFIG_KEYS=(
    ROS_DISTRO
    ROS_INSTALL_TYPE
    ROS_DOMAIN_ID
    PROJECT_NAME
    INSTALL_MICRO_ROS
    LAUNCH_COMMAND
    IMAGE_NAME
    IMAGE_STRATEGY
    GROOT_VERSION
    GROOT_FALLBACK_VERSIONS
    GROOT_APPIMAGE_URL
    GROOT_SHA256
    QGC_VERSION
    QGC_APPIMAGE_URL
    QGC_SHA256
    FOXGLOVE_PORT
    FOXGLOVE_ADDRESS
)

trim_whitespace() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

is_supported_config_key() {
    local key="$1"
    local k
    for k in "${CONFIG_KEYS[@]}"; do
        if [[ "${k}" == "${key}" ]]; then
            return 0
        fi
    done
    return 1
}

set_runtime_var() {
    local key="$1"
    local value="$2"
    case "${key}" in
        ROS_DISTRO|ROS_INSTALL_TYPE|ROS_DOMAIN_ID|PROJECT_NAME|INSTALL_MICRO_ROS|LAUNCH_COMMAND|IMAGE_NAME|IMAGE_STRATEGY|GROOT_VERSION|GROOT_FALLBACK_VERSIONS|GROOT_APPIMAGE_URL|GROOT_SHA256|QGC_VERSION|QGC_APPIMAGE_URL|QGC_SHA256|FOXGLOVE_PORT|FOXGLOVE_ADDRESS)
            printf -v "${key}" '%s' "${value}"
            ;;
        *)
            return 1
            ;;
    esac
}

load_user_config_defaults() {
    [[ -f "${CONFIG_FILE}" ]] || return 0

    local raw line key value
    while IFS= read -r raw || [[ -n "${raw}" ]]; do
        line="$(trim_whitespace "${raw}")"
        [[ -z "${line}" ]] && continue
        [[ "${line}" == \#* ]] && continue
        [[ "${line}" != *"="* ]] && continue

        key="$(trim_whitespace "${line%%=*}")"
        value="$(trim_whitespace "${line#*=}")"

        if ! is_supported_config_key "${key}"; then
            continue
        fi

        if [[ -z "${!key+x}" ]]; then
            set_runtime_var "${key}" "${value}"
        fi
    done < "${CONFIG_FILE}"
}

load_user_config_defaults

ROS_DISTRO="${ROS_DISTRO:-${DEFAULT_ROS_DISTRO}}"
ROS_INSTALL_TYPE="${ROS_INSTALL_TYPE:-${DEFAULT_ROS_INSTALL_TYPE}}"
ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-${DEFAULT_ROS_DOMAIN_ID}}"
PROJECT_NAME="${PROJECT_NAME:-${DEFAULT_PROJECT_NAME}}"
INSTALL_MICRO_ROS="${INSTALL_MICRO_ROS:-${DEFAULT_INSTALL_MICRO_ROS}}"
LAUNCH_COMMAND="${LAUNCH_COMMAND:-${DEFAULT_LAUNCH_COMMAND}}"
case "${ROS_INSTALL_TYPE}" in
    ros-base)
        IMAGE_FLAVOR_TAG="base"
        ;;
    development)
        IMAGE_FLAVOR_TAG="dev"
        ;;
    desktop)
        IMAGE_FLAVOR_TAG="desktop"
        ;;
    *)
        IMAGE_FLAVOR_TAG="${ROS_INSTALL_TYPE}"
        ;;
esac
IMAGE_NAME="${IMAGE_NAME:-${DEFAULT_IMAGE_REPOSITORY}:${ROS_DISTRO}-${IMAGE_FLAVOR_TAG}}"
IMAGE_STRATEGY="${IMAGE_STRATEGY:-${DEFAULT_IMAGE_STRATEGY}}"
GROOT_VERSION="${GROOT_VERSION:-${DEFAULT_GROOT_VERSION}}"
GROOT_FALLBACK_VERSIONS="${GROOT_FALLBACK_VERSIONS:-${DEFAULT_GROOT_FALLBACK_VERSIONS}}"
GROOT_APPIMAGE_URL="${GROOT_APPIMAGE_URL:-}"
GROOT_SHA256="${GROOT_SHA256:-}"
QGC_VERSION="${QGC_VERSION:-${DEFAULT_QGC_VERSION}}"
QGC_APPIMAGE_URL="${QGC_APPIMAGE_URL:-}"
QGC_SHA256="${QGC_SHA256:-}"
FOXGLOVE_PORT="${FOXGLOVE_PORT:-${DEFAULT_FOXGLOVE_PORT}}"
FOXGLOVE_ADDRESS="${FOXGLOVE_ADDRESS:-${DEFAULT_FOXGLOVE_ADDRESS}}"
AUTO_BUILD="false"
AUTO_RUN="false"

ACTION="${1:-}"
shift || true
ACTION_ARGS=("$@")
CUSTOM_COMMAND="${*:-}"

XHOST_OPENED="false"

# ANSI color palette for CLI output (minimal professional style).
C_RESET=$'\033[0m'
C_TITLE=$'\033[1;97m'
C_SECTION=$'\033[1;38;5;250m'
C_CMD=$'\033[1;38;5;45m'
C_LABEL=$'\033[1;38;5;110m'
C_VALUE=$'\033[38;5;252m'
C_MUTED=$'\033[38;5;244m'

compose() {
    (cd "${DOCKER_DIR}" && docker compose "$@")
}

docker_accessible() {
    docker info >/dev/null 2>&1
}

container_running() {
    docker ps --filter "name=^/${PROJECT_NAME}$" --filter "status=running" -q | grep -q .
}

