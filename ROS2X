ensure_config_dir() {
    mkdir -p "${CONFIG_DIR}"
}

write_default_config_file() {
    local target_file="${1:-${CONFIG_FILE}}"
    cat > "${target_file}" <<EOF
# ROS2X persistent configuration
# This file is read by ./ROS2X.
# Environment variables passed inline still have higher priority.
#
# Example:
#   ROS_DOMAIN_ID=12
#   IMAGE_STRATEGY=build

ROS_DISTRO=${DEFAULT_ROS_DISTRO}
ROS_INSTALL_TYPE=${DEFAULT_ROS_INSTALL_TYPE}
ROS_DOMAIN_ID=${DEFAULT_ROS_DOMAIN_ID}
PROJECT_NAME=${DEFAULT_PROJECT_NAME}
INSTALL_MICRO_ROS=${DEFAULT_INSTALL_MICRO_ROS}
LAUNCH_COMMAND=${DEFAULT_LAUNCH_COMMAND}
# Leave empty to auto-generate: ${DEFAULT_IMAGE_REPOSITORY}:<ROS_DISTRO>-<flavor>
IMAGE_NAME=
IMAGE_STRATEGY=${DEFAULT_IMAGE_STRATEGY}
GROOT_VERSION=${DEFAULT_GROOT_VERSION}
GROOT_FALLBACK_VERSIONS=${DEFAULT_GROOT_FALLBACK_VERSIONS}
GROOT_APPIMAGE_URL=
GROOT_SHA256=
QGC_VERSION=${DEFAULT_QGC_VERSION}
QGC_APPIMAGE_URL=
QGC_SHA256=
FOXGLOVE_PORT=${DEFAULT_FOXGLOVE_PORT}
FOXGLOVE_ADDRESS=${DEFAULT_FOXGLOVE_ADDRESS}
EOF
}

ensure_config_file() {
    ensure_config_dir
    if [[ ! -f "${CONFIG_FILE}" ]]; then
        if [[ -f "${CONFIG_TEMPLATE_FILE}" ]]; then
            cp "${CONFIG_TEMPLATE_FILE}" "${CONFIG_FILE}"
        else
            write_default_config_file "${CONFIG_FILE}"
        fi
    fi
}

set_persisted_config_value() {
    local key="$1"
    local value="$2"
    ensure_config_file

    local tmp_file
    tmp_file="$(mktemp)"
    local replaced="false"
    local raw line current_key

    while IFS= read -r raw || [[ -n "${raw}" ]]; do
        line="$(trim_whitespace "${raw}")"
        if [[ -n "${line}" && "${line}" != \#* && "${line}" == *"="* ]]; then
            current_key="$(trim_whitespace "${line%%=*}")"
            if [[ "${current_key}" == "${key}" ]]; then
                printf "%s=%s\n" "${key}" "${value}" >> "${tmp_file}"
                replaced="true"
                continue
            fi
        fi
        printf "%s\n" "${raw}" >> "${tmp_file}"
    done < "${CONFIG_FILE}"

    if [[ "${replaced}" != "true" ]]; then
        printf "%s=%s\n" "${key}" "${value}" >> "${tmp_file}"
    fi

    mv "${tmp_file}" "${CONFIG_FILE}"
}

unset_persisted_config_value() {
    local key="$1"
    ensure_config_file

    local tmp_file
    tmp_file="$(mktemp)"
    local raw line current_key

    while IFS= read -r raw || [[ -n "${raw}" ]]; do
        line="$(trim_whitespace "${raw}")"
        if [[ -n "${line}" && "${line}" != \#* && "${line}" == *"="* ]]; then
            current_key="$(trim_whitespace "${line%%=*}")"
            if [[ "${current_key}" == "${key}" ]]; then
                continue
            fi
        fi
        printf "%s\n" "${raw}" >> "${tmp_file}"
    done < "${CONFIG_FILE}"

    mv "${tmp_file}" "${CONFIG_FILE}"
}

get_persisted_config_value() {
    local key="$1"
    [[ -f "${CONFIG_FILE}" ]] || return 1

    local raw line current_key value
    while IFS= read -r raw || [[ -n "${raw}" ]]; do
        line="$(trim_whitespace "${raw}")"
        [[ -z "${line}" || "${line}" == \#* ]] && continue
        [[ "${line}" != *"="* ]] && continue
        current_key="$(trim_whitespace "${line%%=*}")"
        if [[ "${current_key}" == "${key}" ]]; then
            value="$(trim_whitespace "${line#*=}")"
            printf "%s" "${value}"
            return 0
        fi
    done < "${CONFIG_FILE}"

    return 1
}

print_supported_config_keys() {
    local k
    for k in "${CONFIG_KEYS[@]}"; do
        echo "  - ${k}"
    done
}

print_config_key_options() {
    local key="$1"
    case "${key}" in
        ROS_INSTALL_TYPE)
            echo "  - ros-base"
            echo "  - desktop"
            echo "  - development"
            ;;
        IMAGE_STRATEGY)
            echo "  - auto"
            echo "  - pull"
            echo "  - build"
            ;;
        INSTALL_MICRO_ROS)
            echo "  - true"
            echo "  - false"
            ;;
        ROS_DOMAIN_ID)
            echo "  - Integer 0-232 (recommended default: 0)"
            ;;
        FOXGLOVE_PORT)
            echo "  - Integer 1-65535 (recommended default: 8765)"
            ;;
        FOXGLOVE_ADDRESS)
            echo "  - IP/host bind address (recommended default: 0.0.0.0)"
            ;;
        QGC_VERSION)
            echo "  - latest"
            echo "  - specific version like 5.0.8 (or v5.0.8)"
            ;;
        *)
            echo "  - (free text)"
            ;;
    esac
}

print_config_key_hint() {
    local key="$1"
    echo "Key: ${key}"
    echo "Allowed values:"
    print_config_key_options "${key}"
    echo "Example:"
    case "${key}" in
        ROS_INSTALL_TYPE)
            echo "  ./ROS2X config set ROS_INSTALL_TYPE desktop"
            ;;
        IMAGE_STRATEGY)
            echo "  ./ROS2X config set IMAGE_STRATEGY auto"
            ;;
        INSTALL_MICRO_ROS)
            echo "  ./ROS2X config set INSTALL_MICRO_ROS true"
            ;;
        ROS_DOMAIN_ID)
            echo "  ./ROS2X config set ROS_DOMAIN_ID 0"
            ;;
        FOXGLOVE_PORT)
            echo "  ./ROS2X config set FOXGLOVE_PORT 8765"
            ;;
        FOXGLOVE_ADDRESS)
            echo "  ./ROS2X config set FOXGLOVE_ADDRESS 0.0.0.0"
            ;;
        QGC_VERSION)
            echo "  ./ROS2X config set QGC_VERSION latest"
            ;;
        QGC_APPIMAGE_URL)
            echo "  ./ROS2X config set QGC_APPIMAGE_URL https://example.com/QGroundControl-x86_64.AppImage"
            ;;
        *)
            echo "  ./ROS2X config set ${key} <VALUE>"
            ;;
    esac
}

validate_config_value() {
    local key="$1"
    local value="$2"
    case "${key}" in
        ROS_INSTALL_TYPE)
            case "${value}" in
                ros-base|desktop|development) ;;
                *)
                    echo "Error: ROS_INSTALL_TYPE must be one of: ros-base, desktop, development"
                    return 1
                    ;;
            esac
            ;;
        IMAGE_STRATEGY)
            case "${value}" in
                auto|pull|build) ;;
                *)
                    echo "Error: IMAGE_STRATEGY must be one of: auto, pull, build"
                    return 1
                    ;;
            esac
            ;;
        INSTALL_MICRO_ROS)
            case "${value}" in
                true|false) ;;
                *)
                    echo "Error: INSTALL_MICRO_ROS must be one of: true, false"
                    return 1
                    ;;
            esac
            ;;
        ROS_DOMAIN_ID)
            if ! [[ "${value}" =~ ^[0-9]+$ ]]; then
                echo "Error: ROS_DOMAIN_ID must be an integer between 0 and 232"
                return 1
            fi
            if (( value < 0 || value > 232 )); then
                echo "Error: ROS_DOMAIN_ID must be between 0 and 232"
                return 1
            fi
            ;;
        FOXGLOVE_PORT)
            if ! [[ "${value}" =~ ^[0-9]+$ ]]; then
                echo "Error: FOXGLOVE_PORT must be an integer between 1 and 65535"
                return 1
            fi
            if (( value < 1 || value > 65535 )); then
                echo "Error: FOXGLOVE_PORT must be between 1 and 65535"
                return 1
            fi
            ;;
        FOXGLOVE_ADDRESS)
            if [[ -z "${value}" ]]; then
                echo "Error: FOXGLOVE_ADDRESS cannot be empty"
                return 1
            fi
            ;;
        QGC_VERSION)
            if [[ -z "${value}" ]]; then
                echo "Error: QGC_VERSION cannot be empty (use latest or a concrete version)"
                return 1
            fi
            ;;
        QGC_APPIMAGE_URL)
            if [[ -n "${value}" ]] && [[ ! "${value}" =~ ^https?:// ]]; then
                echo "Error: QGC_APPIMAGE_URL must be an absolute http(s) URL"
                return 1
            fi
            ;;
    esac
}

print_config_command_usage() {
    echo "Usage:"
    echo "  ./ROS2X config"
    echo "  ./ROS2X config path"
    echo "  ./ROS2X config init"
    echo "  ./ROS2X config list"
    echo "  ./ROS2X config keys"
    echo "  ./ROS2X config options <KEY>"
    echo "  ./ROS2X config get <KEY>"
    echo "  ./ROS2X config set <KEY> <VALUE>"
    echo "  ./ROS2X config unset <KEY>"
}

handle_config_command() {
    local subcommand="${1:-show}"

    case "${subcommand}" in
        show)
            show_config
            ;;
        path)
            echo "${CONFIG_FILE}"
            ;;
        init)
            ensure_config_file
            echo "Config file ready: ${CONFIG_FILE}"
            ;;
        list)
            ensure_config_file
            echo "Config file: ${CONFIG_FILE}"
            cat "${CONFIG_FILE}"
            ;;
        keys)
            echo "Supported keys:"
            print_supported_config_keys
            ;;
        options)
            local key="${2:-}"
            if [[ -z "${key}" ]]; then
                echo "Error: Missing key."
                echo "Usage: ./ROS2X config options <KEY>"
                return 1
            fi
            if ! is_supported_config_key "${key}"; then
                echo "Error: Unsupported key '${key}'."
                print_supported_config_keys
                return 1
            fi
            print_config_key_hint "${key}"
            ;;
        get)
            local key="${2:-}"
            if [[ -z "${key}" ]]; then
                echo "Error: Missing key."
                print_config_command_usage
                return 1
            fi
            if ! is_supported_config_key "${key}"; then
                echo "Error: Unsupported key '${key}'."
                print_supported_config_keys
                return 1
            fi
            local persisted=""
            if persisted="$(get_persisted_config_value "${key}")"; then
                echo "${key}=${persisted}"
            else
                echo "${key} is not set in ${CONFIG_FILE}"
            fi
            ;;
        set)
            local key="${2:-}"
            if [[ -z "${key}" ]]; then
                echo "Error: Usage: ./ROS2X config set <KEY> <VALUE>"
                return 1
            fi
            if ! is_supported_config_key "${key}"; then
                echo "Error: Unsupported key '${key}'."
                print_supported_config_keys
                return 1
            fi
            if [[ $# -lt 3 ]]; then
                echo "Error: Missing value for '${key}'."
                print_config_key_hint "${key}"
                return 1
            fi
            shift 2 || true
            local value="$*"
            if ! validate_config_value "${key}" "${value}"; then
                print_config_key_hint "${key}"
                return 1
            fi
            set_persisted_config_value "${key}" "${value}"
            echo "Updated ${key} in ${CONFIG_FILE}"
            ;;
        unset)
            local key="${2:-}"
            if [[ -z "${key}" ]]; then
                echo "Error: Usage: ./ROS2X config unset <KEY>"
                return 1
            fi
            if ! is_supported_config_key "${key}"; then
                echo "Error: Unsupported key '${key}'."
                print_supported_config_keys
                return 1
            fi
            unset_persisted_config_value "${key}"
            echo "Removed ${key} from ${CONFIG_FILE}"
            ;;
        *)
            echo "Error: Unknown config subcommand '${subcommand}'."
            print_config_command_usage
            return 1
            ;;
    esac
}

validate_image_strategy() {
    case "${IMAGE_STRATEGY}" in
        auto|pull|build) ;;
        *)
            echo "Error: IMAGE_STRATEGY must be one of: auto, pull, build"
            exit 1
            ;;
    esac
}

local_image_exists() {
    docker image inspect "${IMAGE_NAME}" >/dev/null 2>&1
}

compose_up_with_strategy() {
    local detached="${1:-false}"
    local -a up_args
    up_args=("${SERVICE_NAME}")
    if [[ "${detached}" == "true" ]]; then
        up_args=(-d "${SERVICE_NAME}")
    fi

    case "${IMAGE_STRATEGY}" in
        build)
            echo "Using local Docker build strategy..."
            compose up --build "${up_args[@]}"
            ;;
        pull)
            echo "Pulling image '${IMAGE_NAME}'..."
            compose pull "${SERVICE_NAME}"
            compose up "${up_args[@]}"
            ;;
        auto)
            if local_image_exists; then
                echo "Using cached local image '${IMAGE_NAME}'."
                compose up "${up_args[@]}"
            else
                echo "No local image found. Trying prebuilt image '${IMAGE_NAME}'..."
                if compose pull "${SERVICE_NAME}"; then
                    compose up "${up_args[@]}"
                else
                    echo "Image pull failed and no local cache found. Falling back to local build..."
                    compose up --build "${up_args[@]}"
                fi
            fi
            ;;
    esac
}

list_apps() {
    echo "Available apps:"
    echo "  - groot"
    echo "  - qgroundcontrol (alias: qgc)"
}

launch_groot() {
    echo "Launching Groot..."
    if ! container_running; then
        echo "Container '${PROJECT_NAME}' is not running. Starting it..."
        compose_up_with_strategy true
    fi

    set +e
    compose exec --user ros ${SERVICE_NAME} bash -lc '
        set -e
        app="/home/ros/ROS2X/apps/groot/groot.AppImage"
        if [ ! -x "${app}" ]; then
            bash "/home/ros/ROS2X/scripts/install_groot2.sh"
        fi
        if [ ! -x "${app}" ]; then
            echo "Error: Groot AppImage is not executable: ${app}" >&2
            exit 1
        fi

        mkdir -p "/home/ros/ROS2X/apps/groot/config" "/home/ros/ROS2X/apps/groot/data"
        export XDG_CONFIG_HOME="/home/ros/ROS2X/apps/groot/config"
        export XDG_DATA_HOME="/home/ros/ROS2X/apps/groot/data"
        export QT_X11_NO_MITSHM=1

        exec "${app}"
    '
    app_status=$?
    set -e
    echo "Groot process exited. Container remains running for other tasks."
    echo "Use './ROS2X close' to stop and remove the container."
    return "${app_status}"
}

launch_qgroundcontrol() {
    echo "Launching QGroundControl..."
    if ! container_running; then
        echo "Container '${PROJECT_NAME}' is not running. Starting it..."
        compose_up_with_strategy true
    fi

    set +e
    compose exec --user ros \
        -e ROS2X_QGC_VERSION="${QGC_VERSION}" \
        -e ROS2X_QGC_APPIMAGE_URL="${QGC_APPIMAGE_URL}" \
        -e ROS2X_QGC_SHA256="${QGC_SHA256}" \
        ${SERVICE_NAME} bash -lc '
            set -e
            app="/home/ros/ROS2X/apps/qgroundcontrol/qgroundcontrol.AppImage"

            if [ ! -x "${app}" ]; then
                QGC_VERSION="${ROS2X_QGC_VERSION}" \
                QGC_APPIMAGE_URL="${ROS2X_QGC_APPIMAGE_URL}" \
                QGC_SHA256="${ROS2X_QGC_SHA256}" \
                    bash "/home/ros/ROS2X/scripts/install_qgroundcontrol.sh"
            fi

            if [ ! -x "${app}" ]; then
                echo "Error: QGroundControl AppImage is not executable: ${app}" >&2
                exit 1
            fi

            mkdir -p "/home/ros/ROS2X/apps/qgroundcontrol/config" "/home/ros/ROS2X/apps/qgroundcontrol/data"
            export XDG_CONFIG_HOME="/home/ros/ROS2X/apps/qgroundcontrol/config"
            export XDG_DATA_HOME="/home/ros/ROS2X/apps/qgroundcontrol/data"
            export QT_X11_NO_MITSHM=1

            # Fallback when /dev/fuse is unavailable in restricted environments.
            if [ ! -e /dev/fuse ]; then
                export APPIMAGE_EXTRACT_AND_RUN=1
            fi

            exec "${app}"
        '
    app_status=$?
    set -e
    echo "QGroundControl exited. Container remains running for other tasks."
    echo "Use './ROS2X close' to stop and remove the container."
    return "${app_status}"
}

launch_app() {
    local app_name="${1:-}"

    if [[ -z "${app_name}" ]]; then
        list_apps
        if [[ -t 0 ]]; then
            read -r -p "Select app: " app_name
        else
            echo "Error: No app specified. Use './ROS2X app <name>'."
            exit 1
        fi
    fi

    case "${app_name}" in
        groot)
            launch_groot
            ;;
        qgroundcontrol|qgc)
            launch_qgroundcontrol
            ;;
        *)
            echo "Error: Unknown app '${app_name}'."
            list_apps
            exit 1
            ;;
    esac
}

